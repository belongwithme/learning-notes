---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';

const entry = Astro.locals.starlightRoute?.entry || Astro.props.entry;
const data = entry?.data || {};
const { status, difficulty, tags } = data;

// 定义状态映射
const statusMap: Record<string, { label: string, icon: string, class: string }> = {
  verified: { label: '已验证', icon: '✅', class: 'status-verified' },
  outdated: { label: '已过期', icon: '⚠️', class: 'status-outdated' },
  draft: { label: '草稿', icon: '📝', class: 'status-draft' },
  evergreen: { label: '常青树', icon: '🌲', class: 'status-evergreen' },
};

// 定义难度映射
const diffMap: Record<string, string> = {
  beginner: '初级',
  intermediate: '中级',
  advanced: '高级'
};

const currentStatus = status ? statusMap[status] : null;
const currentDiff = difficulty ? diffMap[difficulty] : null;
---

<Default {...Astro.props} />

{(currentStatus || currentDiff || (tags && tags.length > 0)) && (
  <div class="page-meta-badges">
    {currentStatus && (
      <span class={`badge ${currentStatus.class}`}>
        <span aria-hidden="true">{currentStatus.icon}</span> {currentStatus.label}
      </span>
    )}
    {currentDiff && (
      <span class="badge badge-difficulty">
        <span aria-hidden="true">🧠</span> 难度: {currentDiff}
      </span>
    )}
    {tags && tags.map((tag: string) => (
      <span class="badge badge-tag">#{tag}</span>
    ))}
  </div>
)}

<style>
  .page-meta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    margin-bottom: 2rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 99px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-text-muted);
  }
  .status-verified, .status-evergreen {
    border-color: var(--archive-accent, var(--sl-color-text-accent));
    color: var(--archive-accent, var(--sl-color-text-accent));
    background: color-mix(in srgb, var(--archive-accent, var(--sl-color-text-accent)) 10%, transparent);
  }
  .status-outdated {
    border-color: #d97706;
    color: #b45309;
    background: color-mix(in srgb, #f59e0b 10%, transparent);
  }
  .badge-tag {
    font-family: var(--sl-font-mono);
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }
</style>
